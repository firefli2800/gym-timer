<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Timer Overlay</title>

<style>
  body {
    margin: 0;
    background: transparent;
    overflow: hidden;
  }

  #timer {
    position: absolute;
    top: 40px;
    right: 60px;
    font-size: 120px;
    font-weight: bold;
    color: white;
    font-family: Arial, sans-serif;
  }
</style>
</head>

<body>

<div id="timer"></div>

<script>
function updateTimer() {
  const now = new Date();
  const seconds = now.getSeconds();

  let cycle = seconds % 60;
  let displayTime;

  if (cycle < 45) {
    displayTime = 45 - cycle;
  } else {
    displayTime = 60 - cycle;
  }

  document.getElementById("timer").innerText = displayTime;
}

setInterval(updateTimer, 1000);
updateTimer();
</script>

</body>
</html>
